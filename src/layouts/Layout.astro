---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Prestique — Custom AI for Your Business',
  description = 'Find out exactly where AI can save your business time and money. Take our free AI audit and get a custom report showing exactly where to start.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://prestique.ai" />
    <meta name="theme-color" content="#0a0f1a" />
  </head>
  <body>
    <slot />
    <script>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
