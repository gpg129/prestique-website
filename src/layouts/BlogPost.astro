---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const AUDIT_URL = 'https://prestique-audit.vercel.app/';
const SITE_URL = 'https://prestique.ai';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  keyword: string;
  vertical: string;
  author?: string;
  readingTime?: number;
  tags?: string[];
  faqs?: Array<{ q: string; a: string }>;
}
const { title, description, pubDate, keyword, vertical, author, readingTime, tags, faqs } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const canonicalURL = Astro.url.href;

const verticalLabel: Record<string, string> = {
  hvac: 'HVAC & Home Services',
  dental: 'Dental & Healthcare',
  law: 'Law Firms',
  auto_repair: 'Auto Repair',
  veterinary: 'Veterinary',
};

// JSON-LD: Article
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: pubDate.toISOString(),
  author: { '@type': 'Organization', name: author ?? 'The Prestique Team' },
  publisher: { '@type': 'Organization', name: 'Prestique', url: SITE_URL },
  url: canonicalURL,
  ...(tags && tags.length > 0 ? { keywords: tags.join(', ') } : {}),
};

// JSON-LD: Breadcrumb
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalURL },
  ],
};

// JSON-LD: FAQ (only if faqs present)
const faqSchema = faqs && faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
} : null;
---
<Layout
  title={`${title} | Prestique`}
  description={description}
  canonicalURL={canonicalURL}
  ogType="article"
  pubDate={pubDate}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <Nav />
  <main class="pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">

      <!-- Post header -->
      <div class="mb-10">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="section-label">{verticalLabel[vertical] ?? vertical}</span>
          <span class="text-p-muted text-sm">·</span>
          <time class="text-p-muted text-sm" datetime={pubDate.toISOString()}>{formattedDate}</time>
          {readingTime && (
            <>
              <span class="text-p-muted text-sm">·</span>
              <span class="text-p-muted text-sm">{readingTime} min read</span>
            </>
          )}
          {author && (
            <>
              <span class="text-p-muted text-sm">·</span>
              <span class="text-p-muted text-sm">{author}</span>
            </>
          )}
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-4">{title}</h1>
        <p class="text-p-muted text-lg leading-relaxed">{description}</p>
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map(tag => (
              <span class="text-xs px-2 py-1 rounded-full border border-white/10 text-p-muted">{tag}</span>
            ))}
          </div>
        )}
        <div class="glow-divider mt-8"></div>
      </div>

      <!-- Post body -->
      <article class="prose-blog">
        <slot />
      </article>

      <!-- FAQ accordion (rendered from frontmatter — structured data + UX) -->
      {faqs && faqs.length > 0 && (
        <div class="mt-12">
          <h2 class="text-xl font-bold text-white mb-6">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqs.map(faq => (
              <details class="glass-card p-5 group cursor-pointer">
                <summary class="font-medium text-white list-none flex justify-between items-center gap-4">
                  <span>{faq.q}</span>
                  <span class="text-p-muted shrink-0 text-lg leading-none">+</span>
                </summary>
                <p class="text-p-muted mt-3 leading-relaxed">{faq.a}</p>
              </details>
            ))}
          </div>
        </div>
      )}

      <!-- Inline audit CTA -->
      <div class="mt-16 glass-card p-8 md:p-10 text-center relative overflow-hidden">
        <div class="absolute inset-0 pointer-events-none"
             style="background: radial-gradient(ellipse at 50% 0%, rgba(26,46,74,0.5) 0%, transparent 70%);"></div>
        <div class="absolute top-0 left-0 right-0 h-px"
             style="background: linear-gradient(90deg, transparent, rgba(59,130,246,0.4), transparent);"></div>
        <div class="relative">
          <p class="section-label mb-3">Free for Your Business</p>
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
            Find out exactly where AI can help your business
          </h2>
          <p class="text-p-muted mb-7 max-w-lg mx-auto">
            The Prestique AI Audit is run by an AI agent — it asks about your business, identifies your top automation opportunities, and delivers a personalized report in about 5 minutes. No forms, no sales call, no pitch.
          </p>
          <a href={AUDIT_URL} class="btn-primary text-base px-8 py-3" target="_blank" rel="noopener">
            Take the Free Audit →
          </a>
          <p class="text-p-muted text-sm mt-4">Free &nbsp;·&nbsp; Powered by AI &nbsp;·&nbsp; Custom to your business</p>
        </div>
      </div>

    </div>
  </main>
  <Footer />
</Layout>
