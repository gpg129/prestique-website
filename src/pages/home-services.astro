---
import { getCollection } from 'astro:content'
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import VerticalHero from '../components/VerticalHero.astro'
import SpecStudy from '../components/SpecStudy.astro'
import VerticalFAQ from '../components/VerticalFAQ.astro'
import LeadForm from '../components/LeadForm.astro'
import Footer from '../components/Footer.astro'
import { VERTICALS } from '../lib/verticals'
import { homeServicesSpec } from '../lib/specStudies/home-services'
import '../styles/global.css'

const vertical = VERTICALS['home-services']!

const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const relatedPosts = allPosts
  .filter((p) => p.data.vertical === 'hvac')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)

const canonical = 'https://prestique.ai/home-services'
---
<Layout
  title={vertical.metaTitle}
  description={vertical.metaDescription}
  canonicalURL={canonical}
>
  <Nav />
  <main>
    <VerticalHero
      industry={vertical.industry}
      headline={vertical.headline}
      subhead={vertical.subhead}
      statBadge={vertical.statBadge}
    />

    <SpecStudy spec={homeServicesSpec} industry={vertical.industry} />

    <!-- Embedded audit form -->
    <section id="audit-form" class="py-24 px-6">
      <div class="glow-divider mb-24"></div>
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12 fade-up">
          <p class="section-label mb-4">Free Audit</p>
          <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-6">
            See what we'd build for your shop.
          </h2>
          <p class="text-p-muted text-lg leading-relaxed max-w-xl mx-auto">
            Aria walks you through a 5-minute discovery and emails back a custom report — top automation opportunities, estimated revenue impact, and what we'd build first.
          </p>
        </div>
        <div class="glass-card p-8 md:p-10 fade-up">
          <LeadForm industry={vertical.industry} />
        </div>
      </div>
    </section>

    <VerticalFAQ faqs={homeServicesSpec.faqs} industry={vertical.industry} />

    {relatedPosts.length > 0 && (
      <section class="py-24 px-6">
        <div class="glow-divider mb-24"></div>
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-12 fade-up">
            <p class="section-label mb-4">Further reading</p>
            <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight">
              From the Prestique blog.
            </h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {relatedPosts.map((post, i) => (
              <a
                href={`/blog/${post.slug}`}
                class="glass-card p-6 hover:bg-p-navy/40 transition-colors fade-up flex flex-col"
                style={`transition-delay: ${0.05 * i}s;`}
              >
                <p class="text-xs text-p-blue uppercase tracking-wider mb-3">HVAC</p>
                <h3 class="text-white font-semibold text-lg leading-snug mb-3 flex-1">
                  {post.data.title}
                </h3>
                <p class="text-p-muted text-sm leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>
                <p class="text-p-glow text-sm mt-4 font-medium">Read post →</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
</Layout>
