---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const verticalLabel: Record<string, string> = {
  hvac: 'HVAC & Home Services',
  dental: 'Dental & Healthcare',
  law: 'Law Firms',
  restaurant: 'Restaurants',
  general: 'AI Automation',
};
---
<Layout
  title="Blog — AI Automation Insights for Small Business | Prestique"
  description="Practical guides on how small businesses use AI automation to stop missing calls, reduce no-shows, and grow revenue. From the team at Prestique."
>
  <Nav />
  <main class="pt-28 pb-20 px-6">
    <div class="max-w-5xl mx-auto">

      <!-- Header -->
      <div class="mb-14 fade-up">
        <p class="section-label mb-3">Prestique Blog</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
          AI Automation for<br class="hidden md:block" /> Small Business
        </h1>
        <p class="text-p-muted text-lg max-w-xl">
          Practical guides on how businesses like yours use AI to stop losing revenue to missed calls, no-shows, and manual work.
        </p>
      </div>

      <!-- Post grid -->
      {posts.length === 0 ? (
        <p class="text-p-muted text-center py-16">Posts coming soon.</p>
      ) : (
        <div class="grid md:grid-cols-2 gap-6">
          {posts.map((post, i) => (
            <a
              href={`/blog/${post.slug}`}
              class="glass-card p-7 flex flex-col gap-4 hover:border-p-blue/30 transition-all duration-200 hover:-translate-y-0.5 fade-up"
              style={`animation-delay: ${i * 60}ms`}
            >
              <div class="flex items-center gap-3">
                <span class="section-label text-[10px]">{verticalLabel[post.data.vertical] ?? post.data.vertical}</span>
                <span class="text-p-muted text-xs">·</span>
                <time class="text-p-muted text-xs" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <h2 class="text-lg font-semibold text-white leading-snug group-hover:text-p-glow">
                {post.data.title}
              </h2>
              <p class="text-p-muted text-sm leading-relaxed flex-1">{post.data.description}</p>
              <span class="text-p-blue text-sm font-medium">Read more →</span>
            </a>
          ))}
        </div>
      )}

    </div>
  </main>
  <Footer />
</Layout>
