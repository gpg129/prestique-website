---
interface Props {
  industry: string
  headline: string
  subhead: string
  statBadge: string
  formAnchor?: string
  specAnchor?: string
}
const {
  industry,
  headline,
  subhead,
  statBadge,
  formAnchor = '#audit-form',
  specAnchor = '#spec-study',
} = Astro.props as Props
---
<section class="relative pt-32 pb-20 px-6 overflow-hidden">
  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px] rounded-full opacity-20"
         style="background: radial-gradient(ellipse, #1a2e4a 0%, transparent 70%);"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[400px] h-[400px] rounded-full opacity-10"
         style="background: radial-gradient(ellipse, #3b82f6 0%, transparent 70%);"></div>
  </div>

  <!-- Grid overlay -->
  <div class="absolute inset-0 opacity-[0.03]"
       style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="relative max-w-5xl mx-auto text-center">
    <!-- Stat badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass-card text-p-blue text-sm font-medium mb-8 fade-up">
      <span class="w-1.5 h-1.5 rounded-full bg-p-blue animate-pulse"></span>
      {statBadge}
    </div>

    <!-- Headline -->
    <h1 class="text-4xl md:text-6xl font-bold text-white leading-[1.1] tracking-tight mb-6 fade-up max-w-4xl mx-auto" style="transition-delay: 0.1s;">
      {headline}
    </h1>

    <!-- Subhead -->
    <p class="text-lg md:text-xl text-p-muted max-w-2xl mx-auto mb-10 leading-relaxed fade-up" style="transition-delay: 0.2s;">
      {subhead}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center fade-up" style="transition-delay: 0.3s;">
      <a href={formAnchor} class="btn-primary text-base px-8 py-4">
        Take the Free Audit →
      </a>
      <a href={specAnchor} class="text-p-glow hover:text-white transition-colors text-base font-medium">
        See what we'd build for {industry} →
      </a>
    </div>
    <p class="text-p-muted text-sm mt-4 fade-up" style="transition-delay: 0.4s;">
      Free &nbsp;·&nbsp; 5 minutes &nbsp;·&nbsp; Custom report
    </p>
  </div>
</section>
