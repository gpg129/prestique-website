---
interface FAQ {
  q: string
  a: string
}
interface Props {
  faqs: FAQ[]
  industry?: string
}
const { faqs, industry } = Astro.props as Props

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---
<section class="py-24 px-6">
  <div class="glow-divider mb-24"></div>
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-12 fade-up">
      <p class="section-label mb-4">FAQ</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight">
        {industry ? `Common questions from ${industry} owners.` : 'Common questions.'}
      </h2>
    </div>

    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <details class="glass-card p-6 group fade-up" style={`transition-delay: ${0.04 * i}s;`}>
          <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
            <h3 class="text-white font-semibold text-base md:text-lg leading-snug">{faq.q}</h3>
            <span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-p-blue transition-transform group-open:rotate-45 text-xl"
                  style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);">
              +
            </span>
          </summary>
          <p class="text-p-muted leading-relaxed mt-4 pr-12">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline></script>

<style>
  details summary::-webkit-details-marker { display: none; }
  details summary::marker { display: none; }
</style>
