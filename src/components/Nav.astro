---
import { VERTICALS } from '../lib/verticals'

const AUDIT_URL = 'https://audit.prestique.ai'

const INDUSTRY_ORDER = ['home-services', 'dental', 'law', 'auto-repair', 'veterinary'] as const
const industries = INDUSTRY_ORDER
  .map((slug) => VERTICALS[slug])
  .filter((v): v is NonNullable<typeof v> => Boolean(v))
---
<nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5"
     style="background: rgba(10, 15, 26, 0.85); backdrop-filter: blur(12px);">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <svg width="42" height="42" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="20,2 36,12 36,28 20,38 4,28 4,12" fill="none" stroke="white" stroke-width="2.5" opacity="0.9"/>
        <polygon points="20,10 30,16 20,22 10,16" fill="#3b82f6" opacity="0.95"/>
        <polygon points="10,16 20,22 20,30 10,24" fill="white" opacity="0.35"/>
        <polygon points="30,16 30,24 20,30 20,22" fill="white" opacity="0.15"/>
      </svg>
      <span class="text-white font-semibold text-3xl tracking-tight">
        Prest<span style="color: #3b82f6;">ique</span>
      </span>
    </a>
    <div class="flex items-center gap-6">
      <div class="hidden sm:block relative" data-industries-dropdown>
        <button
          type="button"
          data-industries-toggle
          aria-haspopup="true"
          aria-expanded="false"
          class="flex items-center gap-1 text-p-muted hover:text-white transition-colors text-sm font-medium py-2"
        >
          Industries
          <svg class="w-3.5 h-3.5 transition-transform duration-200" data-industries-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" />
          </svg>
        </button>

        <div
          data-industries-menu
          class="absolute top-full right-0 mt-2 w-72 rounded-xl overflow-hidden opacity-0 pointer-events-none translate-y-1 transition-all duration-150"
          style="background: rgba(10, 15, 26, 0.97); backdrop-filter: blur(16px); border: 1px solid rgba(96, 165, 250, 0.18); box-shadow: 0 12px 40px rgba(0,0,0,0.5);"
          role="menu"
        >
          <ul class="py-2">
            {industries.map((v) => (
              <li>
                <a
                  href={`/${v.slug}`}
                  role="menuitem"
                  class="flex items-center justify-between gap-3 px-4 py-2.5 text-sm hover:bg-white/5 transition-colors group"
                >
                  <span class="text-white font-medium">{v.label}</span>
                  <span class="text-p-glow text-xs whitespace-nowrap opacity-70 group-hover:opacity-100 transition-opacity">{v.statBadge}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <a href="/blog" class="text-p-muted hover:text-white transition-colors text-sm font-medium">Blog</a>
      <a href={AUDIT_URL} class="btn-primary text-sm" target="_blank" rel="noopener">
        Take the Audit →
      </a>
    </div>
  </div>
</nav>

<script>
  // Industries dropdown — hover-open on devices that support hover, click-toggle elsewhere.
  document.querySelectorAll<HTMLElement>('[data-industries-dropdown]').forEach((root) => {
    const toggle = root.querySelector<HTMLButtonElement>('[data-industries-toggle]')
    const menu = root.querySelector<HTMLElement>('[data-industries-menu]')
    const chevron = root.querySelector<SVGElement>('[data-industries-chevron]')
    if (!toggle || !menu) return

    const open = () => {
      menu.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-1')
      menu.classList.add('opacity-100', 'translate-y-0')
      toggle.setAttribute('aria-expanded', 'true')
      chevron?.classList.add('rotate-180')
    }
    const close = () => {
      menu.classList.add('opacity-0', 'pointer-events-none', 'translate-y-1')
      menu.classList.remove('opacity-100', 'translate-y-0')
      toggle.setAttribute('aria-expanded', 'false')
      chevron?.classList.remove('rotate-180')
    }

    let hoverTimer: number | undefined
    const supportsHover = window.matchMedia('(hover: hover)').matches

    if (supportsHover) {
      root.addEventListener('mouseenter', () => {
        if (hoverTimer) window.clearTimeout(hoverTimer)
        open()
      })
      root.addEventListener('mouseleave', () => {
        hoverTimer = window.setTimeout(close, 120)
      })
    }

    toggle.addEventListener('click', (e) => {
      e.preventDefault()
      const isOpen = toggle.getAttribute('aria-expanded') === 'true'
      isOpen ? close() : open()
    })

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) close()
    })

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close()
    })
  })
</script>
