---
const AUDIT_URL = 'https://prestique-audit.vercel.app/';
---
<nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5"
     style="background: rgba(10, 15, 26, 0.85); backdrop-filter: blur(12px);">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <span class="text-white font-semibold text-lg tracking-tight">
      Prest<span class="text-p-blue">ique</span>
    </span>
    <a href={AUDIT_URL} class="btn-primary text-sm" target="_blank" rel="noopener">
      Take the Audit →
    </a>
  </div>
</nav>
