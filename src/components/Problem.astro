<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 fade-up">
      <p class="section-label mb-4">The Problem</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight">
        Revenue is leaking out of your business<br class="hidden md:block" />
        in places nobody's watching.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Card 1: Missed calls -->
      <div class="glass-card p-8 fade-up" style="transition-delay: 0.1s;">
        <div class="text-p-glow text-3xl font-bold mb-3">50–62%</div>
        <h3 class="text-white font-semibold text-lg mb-3">Missed calls at peak hours</h3>
        <p class="text-p-muted leading-relaxed">
          Service businesses miss half or more of inbound calls when techs are busy. Each one is $400–$600 walking to the next shop on Google.
        </p>
      </div>

      <!-- Card 2: Manual follow-ups -->
      <div class="glass-card p-8 fade-up" style="transition-delay: 0.2s;">
        <div class="text-p-glow text-3xl font-bold mb-3">9pm Sunday</div>
        <h3 class="text-white font-semibold text-lg mb-3">Leads that arrive after hours</h3>
        <p class="text-p-muted leading-relaxed">
          The first to respond books the job. Inquiries that come in nights and weekends get buried by Monday — and the customer is already booked elsewhere.
        </p>
      </div>

      <!-- Card 3: Manual data entry -->
      <div class="glass-card p-8 fade-up" style="transition-delay: 0.3s;">
        <div class="text-p-glow text-3xl font-bold mb-3">5–10 hrs/wk</div>
        <h3 class="text-white font-semibold text-lg mb-3">Owners doing CRM data entry</h3>
        <p class="text-p-muted leading-relaxed">
          Typing call notes, scheduling jobs, updating customer records, chasing quotes. Hours that should be running the business are spent typing into it.
        </p>
      </div>
    </div>
  </div>
</section>
