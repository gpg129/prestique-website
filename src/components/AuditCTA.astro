---
const AUDIT_URL = 'https://audit.prestique.ai';
---
<section class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="glass-card p-12 md:p-16 text-center relative overflow-hidden fade-up">
      <!-- Background glow -->
      <div class="absolute inset-0 pointer-events-none"
           style="background: radial-gradient(ellipse at 50% 0%, rgba(26,46,74,0.6) 0%, transparent 70%);"></div>
      <div class="absolute top-0 left-0 right-0 h-px"
           style="background: linear-gradient(90deg, transparent, rgba(59,130,246,0.5), transparent);"></div>

      <div class="relative">
        <p class="section-label mb-4">Get Started</p>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
          See exactly what we'd build<br class="hidden md:block" /> for your business.
        </h2>
        <p class="text-p-muted text-lg mb-10 max-w-xl mx-auto leading-relaxed">
          5 minutes with Aria. You leave with a custom report — top automation opportunities, estimated revenue impact, and what we'd build first.
        </p>
        <a href={AUDIT_URL} class="btn-primary text-base px-10 py-4 text-lg" target="_blank" rel="noopener">
          Take the Free Audit →
        </a>
        <p class="text-p-muted text-sm mt-6">
          Free &nbsp;·&nbsp; No commitment &nbsp;·&nbsp; Custom to your business
        </p>
      </div>
    </div>
  </div>
</section>
